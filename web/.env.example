# Copy to `.env.local` and fill in. Never commit `.env.local`.

# Deployed Anchor program id (defaults in code if unset)
NEXT_PUBLIC_PROGRAM_ID=5VT57qmHnPuYJaaaXc2fzeywvL9hatirgPggndr1aydk

# Optional: custom RPC (full URL with https://; leave unset or empty to use devnet default)
# NEXT_PUBLIC_RPC=https://api.devnet.solana.com

# Messages (Phase 2 · 6b): signed httpOnly cookies for applicant inbox; operator inbox at /internal/messages
# Production: set both to strong random strings (≥16 chars for session secret).
# MESSAGES_SESSION_SECRET=
# MESSAGES_OPERATOR_SECRET=

# Dev defaults: session uses a built-in dev secret; operator login accepts secret "dev-operator" if MESSAGES_OPERATOR_SECRET is unset.
