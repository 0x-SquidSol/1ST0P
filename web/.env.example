# Copy to `.env.local` and fill in. Never commit `.env.local`.

# Deployed Anchor program id (defaults in code if unset)
NEXT_PUBLIC_PROGRAM_ID=5VT57qmHnPuYJaaaXc2fzeywvL9hatirgPggndr1aydk

# Optional: custom RPC (full URL with https://; leave unset or empty to use devnet default)
# NEXT_PUBLIC_RPC=https://api.devnet.solana.com

# Applicant/operator messaging: signed httpOnly cookies. Production: use strong random values (≥16 chars for session secret).
# MESSAGES_SESSION_SECRET=
# MESSAGES_OPERATOR_SECRET=
# Dev: built-in session signing fallback; operator secret defaults to "dev-operator" if MESSAGES_OPERATOR_SECRET is unset.

# Admin dashboard at /admin — use `local-secrets.env` in this folder (see `local-secrets.example.env`).
# Or set the same variables in `.env.local`. Never commit real values.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# Optional cookie signing key (≥16 chars). If unset, falls back to MESSAGES_SESSION_SECRET, then a dev-only default.
# ADMIN_SESSION_SECRET=
