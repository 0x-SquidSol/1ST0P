# === PUBLIC TEMPLATE ONLY — safe to commit. Do NOT put real passwords here. ===
#
# 1. Copy this file to `local-secrets.env` in the same folder (next to package.json).
# 2. Fill in real values ONLY in `local-secrets.env` (that file is gitignored).
# 3. Restart `npm run dev`.
#
# If admin login says "not configured", the server is reading `local-secrets.env`,
# not this filename.

ADMIN_USERNAME=
ADMIN_PASSWORD=
